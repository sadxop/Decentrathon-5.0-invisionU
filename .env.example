# Copy to .env and fill values (do NOT commit .env)

# Groq (OpenAI-compatible)
GROQ_API_KEY=

# Telegram bot
TELEGRAM_BOT_TOKEN=
BACKEND_API_URL=http://127.0.0.1:8000

# PostgreSQL (override for local dev; Docker sets this automatically)
DATABASE_URL=postgresql://invisionu:invisionu_secret@localhost:5432/invisionu

# JWT secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-in-production
